{
  "name": "schlag",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "playwright test",
    "build:web": "expo export --platform web && cp public/* dist/ 2>/dev/null; sed -i '' 's/<head>/<head><meta name=\"robots\" content=\"noindex, nofollow\" \\/>/g' dist/index.html",
    "deploy": "npm run build:web && wrangler pages deploy dist --project-name schlag"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@shopify/react-native-skia": "2.4.18",
    "expo": "~55.0.5",
    "expo-av": "^16.0.8",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.8",
    "expo-keep-awake": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.4",
    "expo-speech": "~55.0.8",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
